<div class="profile-container">
  <div class="profile-header">
    <h1>Hello, <%= user.username %>!</h1>
    <p class="user-role">Status: <%= user.role || 'Player' %></p> 
  </div>

  <div class="container">
    <h2>Games Played</h2>
    
    <% if (results && results.length > 0) { %>
        <div class="score-grid">
            <% results.forEach(s => { 
                let percent = s.total_questions > 0 ? Math.round((s.score / s.total_questions) * 100) : 0;
            %>
                <div class="score-item">
                    <div class="quiz-info">
                        <strong><%= s.title %></strong>
                        <small><%= new Date(s.completed_at).toLocaleDateString('fi-FI') %></small>
                    </div>
                    
                    <div class="score-value">
                        <span class="points"><%= s.score %> / <%= s.total_questions %></span>
                        
                        <div class="progress-bar-bg" style="margin: 10px 0;">
                            <div class="progress-fill" style="width: <%- percent %>%; background-color: #f1dc8d; height: 100%; border-radius: 5px;"></div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <div class="empty-state" style="text-align: center; padding: 40px;">
            <p>You haven't played any quizzes yet.</p>
            <a href="/" class="btn-discover" style="display: inline-block; margin-top: 15px; background: #154162; color: white; padding: 10px 20px; border-radius: 5px; text-decoration: none;">Find Quizzes</a>
        </div>
    <% } %>
  </div>
</div>