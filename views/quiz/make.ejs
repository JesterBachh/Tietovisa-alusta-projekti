<main class="container">
  <div class="quiz-setup-header">
    <h1><%= query.quiz_id ? 'Add Next Question' : 'Create New Quiz' %></h1>
    <p><%= query.quiz_id ? 'Keep adding questions to your quiz' : 'Fill in the details below to create a new quiz' %></p>
  </div>

  <form action="/quiz/make" method="POST" class="quiz-creation-grid">
    
    <% if (query.quiz_id) { %>
      <input type="hidden" name="quiz_id" value="<%= query.quiz_id %>">
      <input type="hidden" name="category_id" value="<%= query.category_id %>">
    <% } %>

    <div class="left-column">
      <% if (!query.quiz_id) { %>
        <div class="input-block">
          <label>Quiz Title</label>
          <input type="text" name="title" placeholder="e.g., Science Trivia" required>
        </div>

        <div class="input-block">
          <label>Category</label>
          <select name="category_id" id="category-select" required onchange="toggleNewCategoryField()">
            <option value="" disabled selected>Choose category↓</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat.id %>"><%= cat.name %></option>
            <% }); %>
            <option value="new">+ Add New Category...</option>
          </select>
        </div>

        <div id="new-category-input" class="custom-category-box" style="display: none;">
            <label>New Category Name</label>
            <input type="text" name="new_category_name" placeholder="Enter category name...">
            <small>It will be saved automatically with your quiz</small>
        </div>
      <% } else { %>
        <div class="status-card">
          <p><b>Status:</b> Adding questions...</p>
          <a href="/" class="cancel-link">← Cancel and Back</a>
        </div>
      <% } %>
    </div>

    <div class="right-column questions-section">
      <h3>Question Details</h3>
      <div class="question-card">
        <div class="input-block">
            <label>Question Text</label>
            <input type="text" name="question_text" placeholder="Enter your question" required>
        </div>
        
        <p class="instruction-text">Type answers and select the <b>correct</b> one:</p>

        <div class="answers-grid">
          <% [0, 1, 2, 3].forEach(i => { %>
            <div class="answer-row">
              <input type="radio" name="correct_answer_index" value="<%= i %>" <%= i === 0 ? 'checked' : '' %>>
              <input type="text" name="options" placeholder="Answer <%= ['A','B','C','D'][i] %>" required>
            </div>
          <% }) %>
        </div>

        <div class="form-actions">
          <button type="submit" name="action" value="next" class="btn-next">Next Question</button>
          <button type="submit" name="action" value="finish" class="btn-finish">Finish & Save</button>
        </div>
      </div>
    </div>
  </form>
</main>

<script>
function toggleNewCategoryField() {
    const select = document.getElementById('category-select');
    const newCatDiv = document.getElementById('new-category-input');
    const input = newCatDiv.querySelector('input');
    
    if (select.value === 'new') {
        newCatDiv.style.display = 'block';
        input.required = true;
    } else {
        newCatDiv.style.display = 'none';
        input.required = false;
        input.value = '';
    }
}
</script>